# Ports are set directly in docker-compose.yml's `ports:` sections, not here - edit those
# if you need different host ports.

# Frontend Configuration
# BACKEND_URL is read live at request time (frontend/src/middleware.ts), so it's a normal
# runtime setting - changing it just needs a container restart, no rebuild. This line is
# only a reference - docker-compose.yml hardcodes the compose-internal value itself
# ("backend", the stable service name, not the customizable container_name). If you're
# running the containers by hand (README "Option 3") instead of via Compose, set this to
# whatever --name you actually gave the backend container.
BACKEND_URL=http://backend:8000

# NEXT_PUBLIC_API_URL gets compiled into the browser-side JS bundle at build time, so it
# only has any effect when building with `docker compose up --build` (or `docker build`
# directly) - it does nothing if you're just running the prebuilt GHCR images. The
# default of "/api" is correct for the standard setup here (browser calls the frontend's
# own /api/*, which middleware.ts forwards server-side to BACKEND_URL) and normally
# shouldn't need to change.
NEXT_PUBLIC_API_URL=/api

# Kindle Reading Progress Sync (optional)
# Leave blank to disable - the Kindle page will simply show as "not configured".
# The integration runs inside the existing backend container (via curl_cffi); it
# needs NO extra service or TLS proxy.
#
# How to get these values (one-time, valid ~a year):
#   1. Log in to https://read.amazon.com in a browser.
#   2. Open DevTools -> Network, reload the page.
#   3. KINDLE_COOKIES: from any request's "cookie" header, copy at least these
#      four pairs (semicolon-separated): ubid-main, at-main, x-main, session-id.
#      Copying the whole cookie string is fine too.
#   4. KINDLE_DEVICE_TOKEN: find the "getDeviceToken" request and copy the
#      "serialNumber" query parameter value.
KINDLE_COOKIES=
KINDLE_DEVICE_TOKEN=

# Kindle demo mode (no Amazon account or device needed). Set to 1 to make the
# Kindle page serve a small fake library whose progress creeps forward on each
# "Sync Progress Now" - handy for seeing linking, sessions, and streaks work
# end-to-end. Leave blank for real syncing.
KINDLE_MOCK=
