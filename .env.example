# Infrastructure Configuration
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Backend Configuration
DATABASE_PATH=./backend/data/kuzu
LOG_LEVEL=info

# Frontend Configuration
# In Docker: set to /api (proxied via Next.js rewrite to BACKEND_URL)
# In local dev without Docker: set to http://localhost:8000
NEXT_PUBLIC_API_URL=/api
BACKEND_URL=http://localhost:8000
